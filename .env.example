# Zeno Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored. Never commit it.
# Most UI config is done through the in-app Settings panel.

# Required for dev mode
NODE_ENV=development

# LM Studio
# Override default LM Studio URL. Also configurable in-app.
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Obsidian
# Override default vault path. Also configurable in-app.
# OBSIDIAN_VAULT_PATH=C:\Users\you\Documents\ObsidianVault

# Claude API
# Optional. You can enter this in Settings instead. This is only a fallback.
# Get your key from: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# PC Bridge
# Shared secret token for the PC Bridge server.
# Must match the token configured in the bridge server.
# PC_BRIDGE_TOKEN=your-secret-token-here
